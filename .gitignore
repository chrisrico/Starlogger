# virtualenv + bytecode
.venv/
__pycache__/
*.pyc

# downloaded extractor binary (StarBreaker), fetched at runtime
bin/

# per-user runtime data (lives in STARLOGGER_DATA_DIR at runtime, regenerated on run;
# station_names.json is learned/recovered from logs so it's runtime data too)
overrides.json
sessions.json
settings.json
station_names.json
trade_flags.json
*.log

# docs vault (Obsidian): p4k data-model notes + the runtime Game.log catalog —
# kept out of git for now
docs/

# build artifacts
*.tgz
*.zip
dist/

# p4k-derived data extracted from Star Citizen's Data.p4k (via StarBreaker) is NOT
# distributed with the code — bundling extracted game data risks copyright infringement.
# Generated locally at runtime into STARLOGGER_DATA_DIR; regenerated on run when Data.p4k
# is available, otherwise the loaders fall back to empty.
#
# ANY new p4k-derived file must be added here too. As a backstop, the .githooks/pre-commit
# hook blocks committing any *.json carrying the "...Star Citizen Data.p4k via StarBreaker..."
# source marker. Enable it once per clone with: git config core.hooksPath .githooks
# (note: that hook only inspects *.json — the mission_icons/ SVGs below rely on THIS entry.)
ships.json
reference.json
mineables.json
blueprints.json
contracts.json
mission_icons/
# the jukebox's decoded soundtrack: music.json carries the source marker (the pre-commit
# hook also catches it), but the music/ oggs are non-JSON so THIS entry is their only guard.
music.json
music/
