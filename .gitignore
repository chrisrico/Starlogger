# virtualenv + bytecode (match the dir AND a symlink named the same, e.g. a worktree's linked venv)
.venv
.venv-shot
__pycache__/
*.pyc

# Claude Code local working dir (settings, worktrees, plans) — agent-local, not tracked.
# Leaving it untracked dirties the tree, which the updater's clean-tree guard refuses to
# reset over (the in-app "Check for updates" returns "blocked" until the tree is clean).
.claude/

# downloaded extractor binary (StarBreaker), fetched at runtime
bin/

# per-user runtime data (lives in STARLOGGER_DATA_DIR at runtime, regenerated on run;
# station_names.json is learned/recovered from logs so it's runtime data too)
overrides.json
sessions.json
settings.json
station_names.json
trade_flags.json
*.log

# docs vault (Obsidian): p4k data-model notes + the runtime Game.log catalog —
# kept out of git for now
docs/
# internal dev notes
NOTES.md

# build artifacts
*.tgz
*.zip
dist/

# p4k-derived data extracted from Star Citizen's Data.p4k (via StarBreaker) is NOT
# distributed with the code — bundling extracted game data risks copyright infringement.
# Generated locally at runtime into STARLOGGER_DATA_DIR; regenerated on run when Data.p4k
# is available, otherwise the loaders fall back to empty.
#
# ANY new p4k-derived file must be added here too. As a backstop, the .githooks/pre-commit
# hook blocks committing any *.json carrying the "...Star Citizen Data.p4k via StarBreaker..."
# source marker. Enable it once per clone with: git config core.hooksPath .githooks
# (note: that hook only inspects *.json — the mission_icons/ SVGs below rely on THIS entry.)
ships.json
reference.json
mineables.json
salvageables.json
salvage_ships.json
blueprints.json
contracts.json
mining_gear.json
body_mineables.json
space_mineables.json
radar.json
mission_icons/
# Persistent full DataCore extract (records/*.json + global.ini), checked in nowhere. This is
# the raw StarBreaker `dcb extract` output every build_* pass reads — kept on disk so the heavy
# (~146 GB p4k) extraction runs ONCE, not per catalog rebuild. Pure copyrighted game data; the
# pre-commit hook only inspects committed *.json, so THIS entry is its only guard. See NOTES.md
# ("Persistent p4k extract"). NEVER commit or upload.
/p4k/
# the jukebox's decoded soundtrack: music.json carries the source marker (the pre-commit
# hook also catches it), but the music/ oggs are non-JSON so THIS entry is their only guard.
music.json
music/
# per-user jukebox curation (playlist order/hidden/names) is local state, not shipped. The
# shipped default lives at starlogger/default_music_curation.json and IS tracked (pure metadata,
# no p4k audio, no source marker -> the pre-commit hook won't flag it).
music_curation.json
