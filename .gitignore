# virtualenv + bytecode
.venv/
__pycache__/
*.pyc

# downloaded extractor binary (StarBreaker), fetched at runtime
bin/

# per-user runtime data (lives in STARLOGGER_DATA_DIR at runtime, regenerated on run;
# station_names.json is learned/recovered from logs so it's runtime data too)
overrides.json
sessions.json
settings.json
station_names.json
trade_flags.json
*.log

# p4k format/data-model documentation vault (Obsidian) — kept out of git for now
p4k-docs/

# build artifacts
*.tgz
*.zip
dist/

# p4k-derived data extracted from Star Citizen's Data.p4k (via StarBreaker) is NOT
# distributed with the code — bundling extracted game data risks copyright infringement.
# Generated locally at runtime into STARLOGGER_DATA_DIR; regenerated on run when Data.p4k
# is available, otherwise the loaders fall back to empty.
ships_cargo.json
reference.json
mineables.json
blueprints.json
