# virtualenv + bytecode
.venv/
__pycache__/
*.pyc

# downloaded extractor binary (StarBreaker), fetched at runtime
bin/

# per-user runtime data (lives in STARLOGGER_DATA_DIR at runtime, regenerated on run;
# station_names.json is learned/recovered from logs so it's runtime data too)
overrides.json
sessions.json
settings.json
station_names.json
trade_flags.json
*.log

# p4k format/data-model documentation vault (Obsidian) — kept out of git for now
p4k-docs/

# build artifacts
*.tgz
*.zip
dist/

# ships_cargo.json and reference.json (commodity + location maps) are kept tracked:
# committed copies of the latest generated p4k data, shipped with the code purely for
# distribution (runtime reads its own copies in STARLOGGER_DATA_DIR, not these).
